---
interface Props {
  enabled?: boolean;
  position?: 'top' | 'bottom' | 'sidebar';
  adSlot?: string;
}

const { enabled = false, position = 'top', adSlot } = Astro.props;

// Não renderiza se disabled
if (!enabled) {
  return null;
}
---

<div class={`
  ad-banner-container
  ${position === 'sidebar' ? 'lg:sticky lg:top-24' : ''}
  ${position === 'top' ? 'mb-8' : 'mt-8'}
`}>
  <div class="bg-neutral-100 border border-neutral-200 rounded-lg p-4 text-center">
    <!-- Placeholder para Google AdSense -->
    <div class="flex flex-col items-center justify-center min-h-[120px] text-neutral-500">
      <svg class="w-12 h-12 mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7 4v16M17 4v16M3 8h4m10 0h4M3 12h18M3 16h4m10 0h4M4 20h16a1 1 0 001-1V5a1 1 0 00-1-1H4a1 1 0 00-1 1v14a1 1 0 001 1z" />
      </svg>
      <p class="text-xs font-mono">Ad Space</p>
    </div>
    
    <!-- Quando tiver AdSense, descomentar: -->
    <!--
    <ins class="adsbygoogle"
         style="display:block"
         data-ad-client="ca-pub-XXXXXXXXXX"
         data-ad-slot={adSlot}
         data-ad-format="auto"
         data-full-width-responsive="true">
    </ins>
    <script>
      (adsbygoogle = window.adsbygoogle || []).push({});
    </script>
    -->
  </div>
  
  <p class="text-xs text-neutral-400 text-center mt-2">Publicidade</p>
</div>

<style>
  .ad-banner-container {
    transition: opacity 0.3s ease;
  }
  
  .ad-banner-container:hover {
    opacity: 0.9;
  }
</style>
